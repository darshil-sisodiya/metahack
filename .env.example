# Copy this file to .env and fill in your actual values
API_BASE_URL="https://router.huggingface.co/v1"
MODEL_NAME="your-model-name-here"
HF_TOKEN="your-huggingface-or-openai-api-key"

# Optional compatibility fallback for providers that expect the OpenAI variable name.
OPENAI_API_KEY=""

# Submission mode should be `llm`. Local offline smoke tests can use `heuristic`.
OPENENV_AGENT_MODE="llm"

# Keep one deterministic episode per task so runtime stays comfortably below 20 minutes.
OPENENV_EPISODES_PER_TASK="1"
OPENENV_BASE_SEED="42"

# Set to a positive value only if your provider requires extra throttling.
API_CALL_DELAY="0"
